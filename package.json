{
  "name": "qurl",
  "displayName": "Qurl API Client",
  "description": "A REST API client for VS Code",
  "version": "1.0.0",
  "icon": "icon.png",
  "publisher": "GKhandake",
  "repository": {
    "type": "git",
    "url": "https://github.com/gkhandake/qurl.git"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "qurl.open",
        "title": "Qurl: Open API Client"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "qurl-explorer",
          "title": "Qurl",
          "icon": "icon.png"
        }
      ]
    },
    "views": {
      "qurl-explorer": [
        {
          "type": "webview",
          "id": "qurl-sidebar",
          "name": "Qurl Client",
          "icon": "icon.png"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build:webview && npm run package",
    "compile": "webpack --mode development",
    "watch": "webpack --mode development --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "build:webview": "cd webview-ui && npm run build"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.80.0",
    "ts-loader": "^9.4.0",
    "typescript": "^5.0.0",
    "webpack": "^5.80.0",
    "webpack-cli": "^5.0.0"
  },
  "dependencies": {
    "axios": "^1.6.0"
  }
}